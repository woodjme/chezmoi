{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "theme": "system",
  "plugin": [
    "opencode-claude-auth@latest",
    "envsitter-guard@latest",
    "opencode-image-resizer@latest",
    "opencode-history-search",
  ],
  "permission": {
    "websearch": "allow"
  },
  "agent": {
    "build": {
      "enable1mContext": true
    },
    "plan": {
      "enable1mContext": true
    },
    "lite-build": {
      "model": "anthropic/claude-sonnet-4-6",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "todoist": {
      "type": "remote",
      "url": "https://ai.todoist.net/mcp"
    }
  }
}
