{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "theme": "system",
  "plugin": [
    "opencode-claude-auth@latest",
    "envsitter-guard@latest"
  ],
  "agent": {
    "build": {
      "enable1mContext": true
    },
    "plan": {
      "enable1mContext": true
    },
    "lite-build": {
      "model": "anthropic/claude-sonnet-4-6",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
